<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
 "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>com.user.claude-worker</string>
  <key>ProgramArguments</key>
  <array><string>/bin/bash</string><string>-c</string>
    <string>exec "$HOME/agents/scripts/claude-worker.sh"</string></array>
  <key>WatchPaths</key>
  <array><string>/Users/orchestrator/agents/queue</string></array>
  <key>RunAtLoad</key><true/>
  <key>ThrottleInterval</key><integer>30</integer>
  <key>StandardOutPath</key><string>/Users/orchestrator/agents/logs/worker-runner.log</string>
  <key>StandardErrorPath</key><string>/Users/orchestrator/agents/logs/worker-runner.err</string>
</dict></plist>
