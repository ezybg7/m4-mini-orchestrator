<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
 "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>com.user.hermes</string>
  <key>ProgramArguments</key>
  <array><string>/bin/bash</string><string>-c</string>
    <string>export PATH="$HOME/.local/bin:/opt/homebrew/bin:$PATH"; exec hermes gateway</string></array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>StandardOutPath</key><string>/Users/orchestrator/agents/logs/hermes.log</string>
  <key>StandardErrorPath</key><string>/Users/orchestrator/agents/logs/hermes.err</string>
</dict></plist>
